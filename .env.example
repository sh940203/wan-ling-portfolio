# ── 後台 Admin ──────────────────────────────
# 登入 /admin 的密碼（正式環境一定要設一個強密碼）
ADMIN_PASSWORD=
# 用來簽署登入 cookie 的密鑰（隨機長字串，例如 openssl rand -base64 32）
AUTH_SECRET=

# ── 資料庫 ──────────────────────────────────
# 本地開發可留空，會自動用 .data/portfolio.db 檔案資料庫。
# 上線（Vercel）請建一個免費 Turso 資料庫，填入：
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=...
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# ── 聯絡表單寄信（選用，Resend）──────────────
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# ── 速率限制（選用，Upstash Redis）──────────────
# 不設：自動用記憶體版（零設定，適合本地/低流量）。
# 要正式級防護（跨 serverless 實例共用）就到 upstash.com 開免費 Redis 後填入：
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
